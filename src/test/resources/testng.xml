<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Legacy TestNG suite — superseded by Cucumber BDD runners.
  Execute tests via:
    - runners.TestRunner          (all scenarios)
    - runners.GlobalTestRunner    (@global tag)
    - runners.OperatorTestRunner  (@operator tag)
  Maven: mvn test
-->
<suite name="CHQ Automation Suite">

    <test name="Cucumber BDD Tests">
        <classes>
            <class name="runners.TestRunner"/>
        </classes>
    </test>

</suite>
